{
  "name": "badthingsforpets",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "oxfmt '**/*.{ts,tsx,js,mjs}' --ignore-path .gitignore",
    "format:check": "oxfmt --check '**/*.{ts,tsx,js,mjs}' --ignore-path .gitignore",
    "seed:local": "pnpm --filter @btfp/seed run seed:local",
    "cdk": "pnpm --filter @btfp/infra run cdk"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.3.0",
    "typescript": "^5.8.0"
  }
}
