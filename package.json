{
  "name": "badthingsforpets",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "seed:local": "pnpm --filter @btfp/seed run seed:local",
    "cdk": "pnpm --filter @btfp/infra run cdk"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.8.0",
    "prettier": "^3.4.0",
    "eslint": "^9.17.0"
  }
}
